# Retrieval (Real)
NEO4J_URI=bolt+s://<your-neo4j-host>
NEO4J_USER=<your-neo4j-user>
NEO4J_PASSWORD=<your-neo4j-password>
QDRANT_URL=https://<your-qdrant-host>
QDRANT_API_KEY=<your-qdrant-api-key>
QDRANT_COLLECTION=financial_docs
# 로컬/스테이징에서 Qdrant·Neo4j 가 꺼져 있어도 .env 에 URL 이 남아 있을 때 실호출 없이 시드 폴백만 쓰려면 1
RETRIEVAL_FORCE_FALLBACK=0

# LLM (Real)
LLM_BASE_URL=https://<provider-endpoint>/v1/chat/completions
LLM_API_KEY=<your-llm-api-key>
LLM_MODEL=<model-name>

# DART ingestion
DART_API_KEY=<your-dart-api-key>

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
# ── Sprint 7/8 new features ─────────────────────────────────────────────────

# [Item 1] Checkpointer Saver — interrupt/resume persistence
#   local dev:  sqlite:///./checkpoints.db
#   production: postgresql+psycopg://user:password@host/dbname
#   unset → MemorySaver (lost on process restart)
CHECKPOINTER_DSN=

# [Item 1] LangGraph interrupt points (comma-separated, no spaces)
#   e.g. GRAPH_INTERRUPT_BEFORE=retrieve_context  (human-in-the-loop before search)
#   e.g. GRAPH_INTERRUPT_AFTER=evaluation         (review eval result before finish)
GRAPH_INTERRUPT_BEFORE=
GRAPH_INTERRUPT_AFTER=

# [Item 2] Cross-Encoder model for antonym disambiguation
#   requires: pip install sentence-transformers
#   auto-disabled if sentence-transformers not installed
CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# [Item 3] Runtime prompt override directory (hot-swap prompts without redeploy)
#   point to a directory containing <name>.yaml files to override built-in prompts
PROMPT_OVERRIDE_DIR=

# [Item 4] Neo4j adaptive hop traversal (1=enabled, 0=fixed 2-hop)
ADAPTIVE_HOP_ENABLED=1
